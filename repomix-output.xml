import { Injectable, Logger } from '@nestjs/common';
import { Cron } from '@nestjs/schedule';
import { PrismaService } from '../prisma/prisma.service';
import { IncidentsService } from '../incidents/incidents.service';
import { MailService } from '../mail/mail.service';
import { UsersService } from '../users/users.service';
import { WhatsappService } from '../whatsapp/whatsapp.service';

interface IoTPayload {
  device_id?: string;
  temperature: number;
  humidity: number;
  smoke_level: number;
  flame_level: number;
  is_abnormal: boolean;
  timestamp_ms?: number;
}

interface SensorSnapshot {
  temperature: number;
  humidity: number;
  smoke_level: number;
  flame_level: number;
}

interface IncidentDetail {
  sensor: string;
  value: number;
  description: string;
}

@Injectable()
export class SpectoDataService {
  private readonly logger = new Logger(SpectoDataService.name);

  constructor(
    private readonly prisma: PrismaService,
    private readonly incidentsService: IncidentsService,
    private readonly mailService: MailService,
    private readonly usersService: UsersService,
    private readonly whatsappService: WhatsappService,
  ) {}

  // --- MAIN INGESTION LOGIC ---
  async createFromIoT(payload: IoTPayload) {
    this.logger.log(`Received IoT payload: ${JSON.stringify(payload)}`);

    const startTime = Date.now();
    const deviceId = payload.device_id || 'specto-server';

    // 1. Ambil data terakhir DARI PERANGKAT YANG SAMA untuk perbandingan status
    const lastData = await this.prisma.spectoData.findFirst({
      where: { device_id: deviceId },
      orderBy: { created_at: 'desc' },
    });

    // 2. Simpan Data Sensor Mentah
    const saved = await this.prisma.spectoData.create({
      data: {
        device_id: deviceId,
        temperature: payload.temperature,
        humidity: payload.humidity,
        smoke_level: payload.smoke_level,
        flame_level: payload.flame_level,
        is_abnormal: payload.is_abnormal,
      },
    });

    // 3. Cek Perubahan Status & Log Incident (+ Notifikasi) secara async
    //    Jangan await notifikasi agar response cepat
    this.checkStateChangeAndNotify(payload, lastData, deviceId).catch((err) =>
      this.logger.error(`Error in checkStateChangeAndNotify: ${err.message}`),
    );

    const duration = Date.now() - startTime;
    this.logger.log(`createFromIoT processed in ${duration}ms for device ${deviceId}`);

    return saved;
  }

  /**
   * Logika Deteksi Insiden "Rising Edge"
   * Hanya memicu alert jika kondisi berubah dari Aman ke Bahaya.
   * Mencegah spam notifikasi jika bahaya berlangsung lama.
   */
  private async checkStateChangeAndNotify(
    current: IoTPayload,
    previous: SensorSnapshot | null,
    deviceId: string,
  ) {
    const incidentDetails: IncidentDetail[] = [];

    // Label perangkat untuk pesan notifikasi (hanya Specto Server)
    const deviceLabel = 'Server Room';

    // --- THRESHOLD SPECTO SERVER ---
    // Server: 18-27°C, 20-80%
    const TEMP_MIN = 18;
    const TEMP_MAX = 27;
    const HUM_MIN = 20;
    const HUM_MAX = 80;

    const SMOKE_MAX = 4000;
    const FLAME_MIN = 200;

    // --- LOGIC DETEKSI ---

    // 1. SMOKE
    const isSmokeBad = current.smoke_level >= SMOKE_MAX;
    const wasSmokeNormal = !previous || previous.smoke_level < SMOKE_MAX;

    if (isSmokeBad && wasSmokeNormal) {
      incidentDetails.push({
        sensor: 'SMOKE',
        value: current.smoke_level,
        description: `[${deviceLabel}] Smoke detected above threshold`,
      });
    }

    // 2. FLAME
    const isFlameBad = current.flame_level <= FLAME_MIN;
    const wasFlameNormal = !previous || previous.flame_level > FLAME_MIN;

    if (isFlameBad && wasFlameNormal) {
      incidentDetails.push({
        sensor: 'FLAME',
        value: current.flame_level,
        description: `[${deviceLabel}] Fire flame detected`,
      });
    }

    // 3. TEMP
    const isTempBad = current.temperature < TEMP_MIN || current.temperature > TEMP_MAX;
    const wasTempNormal =
      !previous || (previous.temperature >= TEMP_MIN && previous.temperature <= TEMP_MAX);

    if (isTempBad && wasTempNormal) {
      const status = current.temperature > TEMP_MAX ? 'High' : 'Low';
      incidentDetails.push({
        sensor: 'TEMP',
        value: current.temperature,
        description: `[${deviceLabel}] ${status} Temperature detected`,
      });
    }

    // 4. HUMIDITY
    const isHumBad = current.humidity < HUM_MIN || current.humidity > HUM_MAX;
    const wasHumNormal =
      !previous || (previous.humidity >= HUM_MIN && previous.humidity <= HUM_MAX);

    if (isHumBad && wasHumNormal) {
      const status = current.humidity > HUM_MAX ? 'High' : 'Low';
      incidentDetails.push({
        sensor: 'HUM',
        value: current.humidity,
        description: `[${deviceLabel}] ${status} Humidity detected`,
      });
    }

    // --- PROCESS INCIDENTS ---
    for (const incident of incidentDetails) {
      // Simpan Log ke Database, notifikasi akan dikirim otomatis oleh IncidentsService
      await this.incidentsService.createIncident(
        deviceId,
        incident.sensor,
        incident.value,
        incident.description,
      );
    }
  }

  // --- DATA MANAGEMENT (Tiered Storage) ---

  // 1. Rollup ke Per-Jam (Jalan setiap jam di menit ke-5)
  @Cron('0 5 * * * *')
  async aggregateHourlyData() {
    this.logger.log('Running Hourly Aggregation...');

    const end = new Date();
    end.setMinutes(0, 0, 0);
    const start = new Date(end);
    start.setHours(start.getHours() - 1);

    // Group by device_id agar rata-rata tidak tercampur antar alat
    const results = await this.prisma.spectoData.groupBy({
      by: ['device_id'],
      where: { created_at: { gte: start, lt: end } },
      _avg: { temperature: true, humidity: true },
      _max: { smoke_level: true, flame_level: true },
    });

    for (const res of results) {
      await this.prisma.spectoHourly.create({
        data: {
          device_id: res.device_id,
          time_bucket: start,
          avg_temp: res._avg.temperature ?? 0,
          avg_hum: res._avg.humidity ?? 0,
          max_smoke: res._max.smoke_level ?? 0,
          max_flame: res._max.flame_level ?? 0,
        },
      });
      this.logger.log(`Hourly aggregated for ${res.device_id}`);
    }
  }

  // 2. Rollup ke Per-Hari (Jalan jam 01:00 pagi)
  @Cron('0 0 1 * * *')
  async aggregateDailyData() {
    this.logger.log('Running Daily Aggregation...');

    const today = new Date();
    today.setHours(0, 0, 0, 0);
    const yesterday = new Date(today);
    yesterday.setDate(yesterday.getDate() - 1);

    const results = await this.prisma.spectoHourly.groupBy({
      by: ['device_id'],
      where: { time_bucket: { gte: yesterday, lt: today } },
      _avg: { avg_temp: true, avg_hum: true },
      _max: { max_smoke: true, max_flame: true },
    });

    for (const res of results) {
      await this.prisma.spectoDaily.create({
        data: {
          device_id: res.device_id,
          date_bucket: new Date(yesterday.toISOString().split('T')[0]),
          avg_temp: res._avg.avg_temp ?? 0,
          avg_hum: res._avg.avg_hum ?? 0,
          max_smoke: res._max.max_smoke ?? 0,
          max_flame: res._max.max_flame ?? 0,
        },
      });
      this.logger.log(`Daily data aggregated for ${res.device_id} (${yesterday.toISOString()})`);
    }
  }

  // 3. Cleanup Data Lama (Jalan jam 02:00 pagi) - Hapus raw > 7 hari
  @Cron('0 0 2 * * *')
  async cleanupOldRawData() {
    const sevenDaysAgo = new Date();
    sevenDaysAgo.setDate(sevenDaysAgo.getDate() - 7);

    const result = await this.prisma.spectoData.deleteMany({
      where: { created_at: { lt: sevenDaysAgo } },
    });

    this.logger.log(`Cleaned up ${result.count} old raw data rows.`);
  }

  // --- QUERY METHODS (Smart Query with Device ID) ---

  async findHistory(startDate: string, endDate: string, deviceId = 'specto-server') {
    const start = new Date(startDate);
    const end = new Date(endDate);
    const diffHours = (end.getTime() - start.getTime()) / (1000 * 60 * 60);

    // Filter query dengan device_id
    if (diffHours <= 24) {
      return this.prisma.spectoData.findMany({
        where: {
          created_at: { gte: start, lte: end },
          device_id: deviceId,
        },
        orderBy: { created_at: 'asc' },
      });
    } else if (diffHours <= 24 * 30) {
      const data = await this.prisma.spectoHourly.findMany({
        where: {
          time_bucket: { gte: start, lte: end },
          device_id: deviceId,
        },
        orderBy: { time_bucket: 'asc' },
      });
      return data.map((d) => ({
        created_at: d.time_bucket,
        temperature: d.avg_temp,
        humidity: d.avg_hum,
        smoke: d.max_smoke,
        flame: d.max_flame,
      }));
    } else {
      const data = await this.prisma.spectoDaily.findMany({
        where: {
          date_bucket: {
            gte: new Date(startDate.split('T')[0]),
            lte: new Date(endDate.split('T')[0]),
          },
          device_id: deviceId,
        },
        orderBy: { date_bucket: 'asc' },
      });

      return data.map((d) => ({
        created_at: d.date_bucket.toISOString().split('T')[0],
        temperature: d.avg_temp,
        humidity: d.avg_hum,
        // Smoke/Flame max opsional
      }));
    }
  }

  async findLatest(deviceId = 'specto-server') {
    this.logger.log(`Fetching latest data for device: ${deviceId}`);
    const result = await this.prisma.spectoData.findFirst({
      where: { device_id: deviceId },
      orderBy: { created_at: 'desc' },
    });
    this.logger.log(`Latest data result for ${deviceId}: ${result ? 'found' : 'null'}`);
    return result;
  }

  /**
   * Mengambil data agregasi per jam untuk laporan
   */
  async findHourlyStats(startDate: string, endDate: string, deviceId = 'specto-server') {
    const start = new Date(startDate);
    const end = new Date(endDate);

    return this.prisma.spectoHourly.findMany({
      where: {
        time_bucket: { gte: start, lte: end },
        device_id: deviceId,
      },
      orderBy: { time_bucket: 'asc' },
    });
  }
}
